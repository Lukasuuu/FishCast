@page
@model LoginModel

@{
    ViewData["Title"] = "Entrar - FishCast";
    Layout = "_AuthLayout";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-hero">
            <div class="hook-big">🎣</div>
            <h1>FishCast</h1>
            <p>Rede Social de Pesca de Viana do Castelo</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger-fc mb-3" role="alert"></div>

            <div class="form-group mb-3">
                <label asp-for="Input.UsernameOrEmail" class="fc-label">Email ou Nome de utilizador</label>
                <input asp-for="Input.UsernameOrEmail" class="fc-input" autocomplete="username" aria-required="true" placeholder="seu@email.pt ou username" />
                <span asp-validation-for="Input.UsernameOrEmail" class="field-validation-error"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Password" class="fc-label">Palavra-passe</label>
                <input asp-for="Input.Password" type="password" class="fc-input" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>

            <div class="form-group mb-4">
                <label class="d-flex align-items-center gap-2" style="cursor: pointer;">
                    <input class="form-check-input" asp-for="Input.RememberMe" style="accent-color: var(--coral);" />
                    <span style="color: var(--foam-muted); font-size: 13px;">@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                </label>
            </div>

            <button id="login-submit" type="submit" class="btn-coral">
                <i class="bi bi-box-arrow-in-right"></i> Entrar
            </button>

            <div class="auth-divider">
                <span>ou</span>
            </div>

            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn-outline-fc text-center text-decoration-none" style="display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-person-plus"></i> Criar nova conta
            </a>
        </form>

        <div class="auth-link">
            <a id="forgot-password" asp-page="./ForgotPassword">Esqueceu a palavra-passe?</a>
        </div>

        <div class="text-center mt-4" style="font-size: 11px; color: var(--foam-muted);">
            <p class="mb-1">Contas de teste:</p>
            <p class="mb-0">joaominhoto@fishcast.pt / Pesca@2026!</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
