@model FishCast.ViewModels.PeixeDetailViewModel

@{
    ViewData["Title"] = $"{Model.Peixe.Nome} - FishCast";
}

<div class="catalog-page">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none" style="color: var(--foam-muted);">
            <i class="bi bi-arrow-left"></i> Voltar ao catálogo
        </a>
    </div>

    <div class="profile-hero mb-4">
        <div class="d-flex align-items-start gap-4" style="position: relative;">
            <div class="fish-card-img" style="width: 150px; height: 150px; flex-shrink: 0; border-radius: var(--radius);">
                @if (!string.IsNullOrEmpty(Model.Peixe.ImagemUrl))
                {
                    <img src="@Model.Peixe.ImagemUrl" alt="@Model.Peixe.Nome" style="width: 100%; height: 100%; object-fit: cover;">
                }
                else
                {
                    <i class="bi bi-water" style="font-size: 5rem;"></i>
                }
            </div>

            <div class="flex-grow-1">
                <h2 style="color: var(--foam); font-family: 'Playfair Display', serif; margin-bottom: 8px;">
                    <i class="bi bi-water"></i> @Model.Peixe.Nome
                </h2>

                @if (!string.IsNullOrEmpty(Model.Peixe.NomeCientifico))
                {
                    <p style="color: var(--foam-muted); font-style: italic; margin-bottom: 12px;">
                        @Model.Peixe.NomeCientifico
                    </p>
                }

                <div class="d-flex flex-wrap gap-2 mb-3">
                    @if (!string.IsNullOrEmpty(Model.Peixe.HabitatTipo))
                    {
                        <span class="badge-captura badge-peixe">
                            <i class="bi bi-geo-alt"></i> @Model.Peixe.HabitatTipo
                        </span>
                    }
                    @if (Model.Peixe.TamanhoMedioCm.HasValue)
                    {
                        <span class="badge-captura badge-peso">
                            <i class="bi bi-rulers"></i> @Model.Peixe.TamanhoMedioCm cm (médio)
                        </span>
                    }
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <div style="font-size: 12px; color: var(--foam-muted);">Total de Capturas</div>
                        <div style="font-size: 24px; font-weight: 700; color: var(--foam);">@Model.TotalCapturas</div>
                    </div>
                    <div class="col-6">
                        <div style="font-size: 12px; color: var(--foam-muted);">Maior Peso</div>
                        <div style="font-size: 24px; font-weight: 700; color: var(--coral);">
                            @(Model.MaiorPeso?.ToString("F2") ?? "-") @(Model.MaiorPeso.HasValue ? "kg" : "")
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Peixe.Descricao))
                {
                    <p style="color: var(--foam); line-height: 1.6;">@Model.Peixe.Descricao</p>
                }
            </div>
        </div>
    </div>

    @if (Model.Capturas.Any())
    {
        <h4 style="color: var(--foam); margin-bottom: 16px;">
            <i class="bi bi-camera"></i> Capturas Recentes
        </h4>

        <div class="capture-grid">
            @foreach (var captura in Model.Capturas)
            {
                <a asp-controller="Captura" asp-action="Details" asp-route-id="@captura.Id" class="grid-item text-decoration-none">
                    @if (!string.IsNullOrEmpty(captura.ImagemPath))
                    {
                        <img src="@captura.ImagemPath" alt="@captura.Titulo" onerror="this.src='/images/default-captura.svg'">
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100" style="background: var(--ocean-mid);">
                            <i class="bi bi-image" style="font-size: 2rem; color: var(--foam-muted);"></i>
                        </div>
                    }
                    <div class="grid-item-overlay">
                        <i class="bi bi-person"></i>
                        <span>@captura.NomeUtilizador</span>
                        @if (captura.PesoKg.HasValue)
                        {
                            <span>@captura.PesoKg.Value.ToString("F1") kg</span>
                        }
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-camera"></i></div>
            <h3>Ainda não há capturas deste peixe</h3>
            <p>Seja o primeiro a partilhar uma captura de @Model.Peixe.Nome!</p>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Captura" asp-action="Create" class="btn-coral mt-3" style="width: auto; display: inline-flex;">
                    <i class="bi bi-plus-lg"></i> Publicar Captura
                </a>
            }
        </div>
    }
</div>
