@model FishCast.ViewModels.CapturaCreateViewModel

@{
    ViewData["Title"] = "Nova Captura - FishCast";
}

<div class="create-page">
    <div class="create-header">
        <h2><i class="bi bi-camera"></i> Nova Captura</h2>
        <p>Partilhe o seu momento de pesca com a comunidade</p>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="create-card">
        @Html.AntiForgeryToken()

        <div class="p-4">
            <!-- Imagem -->
            <div class="form-group mb-4">
                <label class="fc-label"><i class="bi bi-image"></i> Fotografia da Captura</label>
                <div class="photo-drop" id="photoDrop">
                    <input type="file" asp-for="Imagem" id="fileInput" accept=".jpg,.jpeg,.png,.webp" />
                    <div class="photo-drop-icon" id="dropIcon"><i class="bi bi-cloud-arrow-up"></i></div>
                    <h4>Clique ou arraste uma foto</h4>
                    <p>Formatos: JPG, PNG, WEBP (máx 5MB)</p>
                </div>
                <div class="photo-preview" id="photoPreview">
                    <img id="previewImg" src="" alt="Preview">
                    <button type="button" class="photo-preview-remove" id="removePhoto"><i class="bi bi-x"></i></button>
                </div>
                <span asp-validation-for="Imagem" class="field-validation-error"></span>
            </div>

            <!-- Título -->
            <div class="form-group mb-3">
                <label asp-for="Titulo" class="fc-label">Título</label>
                <input asp-for="Titulo" class="fc-input" placeholder="Ex: Grande captura de hoje!" />
                <span asp-validation-for="Titulo" class="field-validation-error"></span>
            </div>

            <!-- Peixe -->
            <div class="form-group mb-3">
                <label asp-for="PeixeId" class="fc-label">Espécie</label>
                <select asp-for="PeixeId" asp-items="Model.Peixes" class="fc-select">
                    <option value="">Selecione uma espécie</option>
                </select>
                <span asp-validation-for="PeixeId" class="field-validation-error"></span>
            </div>

            <div class="form-grid">
                <!-- Praia -->
                <div class="form-group mb-3">
                    <label asp-for="Praia" class="fc-label">Praia</label>
                    <select asp-for="Praia" class="fc-select">
                        <option value="">Selecione</option>
                        @foreach (var praia in Model.Praias)
                        {
                            <option value="@praia">@praia</option>
                        }
                    </select>
                    <span asp-validation-for="Praia" class="field-validation-error"></span>
                </div>

                <!-- Tipo de Pesca -->
                <div class="form-group mb-3">
                    <label asp-for="TipoPesca" class="fc-label">Tipo de Pesca</label>
                    <select asp-for="TipoPesca" class="fc-select">
                        <option value="">Selecione</option>
                        @foreach (var tipo in Model.TiposPesca)
                        {
                            <option value="@tipo">@tipo</option>
                        }
                    </select>
                    <span asp-validation-for="TipoPesca" class="field-validation-error"></span>
                </div>

                <!-- Maré -->
                <div class="form-group mb-3">
                    <label asp-for="Mare" class="fc-label">Maré</label>
                    <select asp-for="Mare" class="fc-select">
                        <option value="">Selecione</option>
                        @foreach (var mare in Model.Mares)
                        {
                            <option value="@mare">@mare</option>
                        }
                    </select>
                    <span asp-validation-for="Mare" class="field-validation-error"></span>
                </div>

                <!-- Peso -->
                <div class="form-group mb-3">
                    <label asp-for="PesoKg" class="fc-label">Peso (kg)</label>
                    <input asp-for="PesoKg" type="number" step="0.01" min="0" max="99.99" class="fc-input" placeholder="0.00" />
                    <span asp-validation-for="PesoKg" class="field-validation-error"></span>
                </div>

                <!-- Quantidade -->
                <div class="form-group mb-3">
                    <label asp-for="Quantidade" class="fc-label">Quantidade</label>
                    <input asp-for="Quantidade" type="number" min="1" max="999" class="fc-input" />
                    <span asp-validation-for="Quantidade" class="field-validation-error"></span>
                </div>

                <!-- Data -->
                <div class="form-group mb-3">
                    <label asp-for="DataHora" class="fc-label">Data e Hora</label>
                    <input asp-for="DataHora" type="datetime-local" class="fc-input" />
                    <span asp-validation-for="DataHora" class="field-validation-error"></span>
                </div>
            </div>

            <!-- Observações -->
            <div class="form-group mb-3">
                <label asp-for="Observacao" class="fc-label">Observações</label>
                <textarea asp-for="Observacao" class="fc-textarea" rows="3" placeholder="Descreva o momento da captura..."></textarea>
                <span asp-validation-for="Observacao" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-nav">
            <a asp-action="Index" class="btn-outline-fc">Cancelar</a>
            <button type="submit" class="btn-coral"><i class="bi bi-check-lg"></i> Publicar</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function() {
            const fileInput = document.getElementById('fileInput');
            const photoDrop = document.getElementById('photoDrop');
            const photoPreview = document.getElementById('photoPreview');
            const previewImg = document.getElementById('previewImg');
            const removePhoto = document.getElementById('removePhoto');

            if (!fileInput || !photoDrop || !photoPreview || !previewImg || !removePhoto) return;

            fileInput.addEventListener('change', function(e) {
                if (this.files && this.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        if (previewImg) previewImg.src = e.target.result;
                        photoDrop.style.display = 'none';
                        photoPreview.style.display = 'block';
                    };
                    reader.readAsDataURL(this.files[0]);
                }
            });

            removePhoto.addEventListener('click', function() {
                fileInput.value = '';
                photoPreview.style.display = 'none';
                photoDrop.style.display = 'block';
                if (previewImg) previewImg.src = '';
            });

            // Drag and drop
            photoDrop.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = 'var(--coral)';
            });

            photoDrop.addEventListener('dragleave', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = 'var(--card-border)';
            });

            photoDrop.addEventListener('drop', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = 'var(--card-border)';
                if (e.dataTransfer.files.length > 0) {
                    fileInput.files = e.dataTransfer.files;
                    fileInput.dispatchEvent(new Event('change'));
                }
            });
        })();
    </script>
}