@using Microsoft.AspNetCore.Identity
@using FishCast.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var user = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
}

<nav class="navbar-fishcast" id="mainNav">
    <!-- TOGGLE MOBILE -->
    <button class="navbar-toggler d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation" style="background: transparent; border: none; color: var(--foam); padding: 4px; order: -1;">
        <i class="bi bi-list" style="font-size: 1.5rem;"></i>
    </button>

    <!-- LOGO -->
    <a class="navbar-brand-fc" asp-controller="Home" asp-action="Index">
        <div class="hook">🎣</div>
        <span class="brand-font">FishCast</span>
    </a>

    <!-- NAV LINKS + SEARCH -->
    <div class="collapse navbar-collapse d-md-flex" id="navMenu" style="flex-grow: 0;">
        <div class="nav-links d-flex flex-column flex-md-row align-items-start align-items-md-center">
            <a class="nav-btn" asp-controller="Home" asp-action="Index" title="Feed">
                <i class="bi bi-house-fill"></i> <span class="d-md-none ms-2">Feed</span>
            </a>
            <a class="nav-btn" asp-controller="Explorar" asp-action="Index" title="Explorar">
                <i class="bi bi-compass"></i> <span class="d-md-none ms-2">Explorar</span>
            </a>
            <a class="nav-btn" asp-controller="Peixe" asp-action="Index" title="Peixes">
                <i class="bi bi-water"></i> <span class="d-md-none ms-2">Peixes</span>
            </a>
        </div>

        <form asp-controller="Explorar" asp-action="Index" method="get" class="nav-search">
            <i class="bi bi-search"></i>
            <input type="text" name="termoPesquisa" placeholder="Pesquisar..." value="@Context.Request.Query["termoPesquisa"]">
        </form>
    </div>

    <div class="nav-actions">
        @if (SignInManager.IsSignedIn(User))
        {
            <div style="display:flex;align-items:center;gap:8px">
                <a class="btn-post-nav d-none d-sm-flex" asp-controller="Captura" asp-action="Create">
                    <i class="bi bi-camera"></i> Publicar
                </a>

                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-decoration-none" data-bs-toggle="dropdown" aria-expanded="false">
                        @if (!string.IsNullOrEmpty(user?.FotoPerfil))
                        {
                            <img src="@user.FotoPerfil" class="avatar-sm" alt="Perfil">
                        }
                        else
                        {
                            <img src="~/images/default-avatar.svg" class="avatar-sm" alt="Perfil" onerror="this.src='/images/default-avatar.svg'">
                        }
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" style="background: var(--ocean-navy); border-color: var(--card-border);">
                        <li>
                            <a class="dropdown-item" asp-controller="Perfil" asp-action="Index" style="color: var(--white);">
                                <i class="bi bi-person"></i> Meu Perfil
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Captura" asp-action="Index" style="color: var(--white);">
                                <i class="bi bi-collection"></i> Minhas Capturas
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" style="border-color: var(--card-border);"></li>
                        <li>
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                <button type="submit" class="dropdown-item" style="color: var(--coral); border: none; background: none; width: 100%; text-align: left;">
                                    <i class="bi bi-box-arrow-right"></i> Sair
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        }
        else
        {
            <div style="display:flex;gap:8px;align-items:center">
                <a class="btn-outline-fc d-none d-sm-inline-block" asp-area="Identity" asp-page="/Account/Login">
                    Entrar
                </a>
                <a class="btn-coral" asp-area="Identity" asp-page="/Account/Register">
                    Registar
                </a>
            </div>
        }
    </div>
</nav>
