@model FishCast.ViewModels.PerfilEditViewModel

@{
    ViewData["Title"] = "Editar Perfil - FishCast";
    var avatarUrl = !string.IsNullOrEmpty(Model.FotoPerfilAtual) ? Model.FotoPerfilAtual : "/images/default-avatar.svg";
}

<div class="create-page">
    <div class="create-header">
        <h2><i class="bi bi-person-gear"></i> Editar Perfil</h2>
        <p>Atualize os dados do seu perfil</p>
    </div>

    <form asp-action="Editar" method="post" enctype="multipart/form-data" class="create-card">
        @Html.AntiForgeryToken()

        <div class="p-4">
            <!-- Foto de Perfil -->
            <div class="form-group mb-4">
                <label class="fc-label"><i class="bi bi-image"></i> Foto de Perfil</label>

                <div class="mb-3 text-center">
                    <img src="@avatarUrl" id="avatarPreview" alt="Avatar" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid var(--coral);"
                         onerror="this.src='/images/default-avatar.svg'">
                </div>

                <div class="photo-drop" id="photoDrop">
                    <input type="file" asp-for="NovaFotoPerfil" id="fileInput" accept=".jpg,.jpeg,.png,.webp" />
                    <div class="photo-drop-icon" id="dropIcon"><i class="bi bi-camera"></i></div>
                    <h4>Alterar foto (opcional)</h4>
                    <p>Clique para escolher uma nova foto (máx 5MB)</p>
                </div>
            </div>

            <!-- Nome -->
            <div class="form-group mb-3">
                <label asp-for="Nome" class="fc-label">Nome</label>
                <input asp-for="Nome" class="fc-input" placeholder="O seu nome" />
                <span asp-validation-for="Nome" class="field-validation-error"></span>
            </div>

            <!-- Bio -->
            <div class="form-group mb-3">
                <label asp-for="Bio" class="fc-label">Bio</label>
                <textarea asp-for="Bio" class="fc-textarea" rows="3" placeholder="Fale um pouco sobre si..."></textarea>
                <span asp-validation-for="Bio" class="field-validation-error"></span>
            </div>

            <div class="form-grid">
                <!-- Localidade -->
                <div class="form-group mb-3">
                    <label asp-for="Localidade" class="fc-label">Localidade</label>
                    <select asp-for="Localidade" class="fc-select">
                        <option value="">Selecione</option>
                        @foreach (var loc in Model.Localidades)
                        {
                            <option value="@loc">@loc</option>
                        }
                    </select>
                    <span asp-validation-for="Localidade" class="field-validation-error"></span>
                </div>

                <!-- Tipo de Pesca Favorito -->
                <div class="form-group mb-3">
                    <label asp-for="TipoPescaFavorito" class="fc-label">Tipo de Pesca Favorito</label>
                    <select asp-for="TipoPescaFavorito" class="fc-select">
                        <option value="">Selecione</option>
                        @foreach (var tipo in Model.TiposPesca)
                        {
                            <option value="@tipo">@tipo</option>
                        }
                    </select>
                    <span asp-validation-for="TipoPescaFavorito" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="form-nav">
            <a asp-action="Index" class="btn-outline-fc">Cancelar</a>
            <button type="submit" class="btn-coral"><i class="bi bi-check-lg"></i> Guardar</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function() {
            const fileInput = document.getElementById('fileInput');
            const avatarPreview = document.getElementById('avatarPreview');

            if (!fileInput || !avatarPreview) return;

            fileInput.addEventListener('change', function(e) {
                if (this.files && this.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        avatarPreview.src = e.target.result;
                    };
                    reader.readAsDataURL(this.files[0]);
                }
            });
        })();
    </script>
}